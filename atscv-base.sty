\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{atscv-base}[2026/05/03 ATSCV base tokens]

\RequirePackage{xcolor}
\RequirePackage[margin=1in]{geometry}
\RequirePackage{ifthen}

% State tokens (defined once only)
\newcommand{\atscvPreset}{none}
\newcommand{\atscvSchema}{general}
\newcommand{\atscvColor}{default}
\newcommand{\atscvStyle}{default}
\newcommand{\atscvLayout}{standard}
\newcommand{\atscvLanguage}{en}

% Color tokens
\definecolor{cvtext}{HTML}{111111}
\definecolor{cvprimary}{HTML}{1A1A1A}
\definecolor{cvaccent}{HTML}{1E6F5C}
\definecolor{cvmuted}{HTML}{666666}
\definecolor{cvdivider}{HTML}{D9D9D9}

% Typography tokens
\newcommand{\atscvNameSize}{\LARGE}
\newcommand{\atscvTitleSize}{\large}
\newcommand{\atscvSectionSize}{\normalsize}

% Layout tokens
\newcommand{\atscvSectionBefore}{\vspace{0.9\baselineskip}}
\newcommand{\atscvSectionAfter}{\vspace{0.3\baselineskip}}
\newcommand{\atscvEntrySpace}{\vspace{0.2\baselineskip}}
\newcommand{\atscvDividerThickness}{0.4pt}

\newcommand{\atscvifempty}[3]{%
  \if\relax\detokenize{#1}\relax #2\else #3\fi
}

% Heading labels
\newcommand{\atscvHeadingSummary}{Summary}
\newcommand{\atscvHeadingExperience}{Experience}
\newcommand{\atscvHeadingEducation}{Education}
\newcommand{\atscvHeadingSkills}{Skills}
\newcommand{\atscvHeadingProjects}{Projects}
\newcommand{\atscvHeadingCertifications}{Certifications}
\newcommand{\headingSummary}{\atscvHeadingSummary}
\newcommand{\headingExperience}{\atscvHeadingExperience}
\newcommand{\headingEducation}{\atscvHeadingEducation}
\newcommand{\headingSkills}{\atscvHeadingSkills}
\newcommand{\headingProjects}{\atscvHeadingProjects}
\newcommand{\headingCertifications}{\atscvHeadingCertifications}

\newcommand{\cvdebugoptions}{%
  \par\noindent Preset: \atscvPreset\par
  Schema: \atscvSchema\par
  Color: \atscvColor\par
  Style: \atscvStyle\par
  Layout: \atscvLayout\par
  Language: \atscvLanguage\par
  NameSize: \meaning\atscvNameSize\par
  TitleSize: \meaning\atscvTitleSize\par
  SectionSize: \meaning\atscvSectionSize\par
  SectionBefore: \meaning\atscvSectionBefore\par
  SectionAfter: \meaning\atscvSectionAfter\par
  EntrySpace: \meaning\atscvEntrySpace\par
  DividerThickness: \atscvDividerThickness\par
  \typeout{ATSCV CONFIG color=\atscvColor}%
  \typeout{ATSCV CONFIG style=\atscvStyle}%
  \typeout{ATSCV CONFIG layout=\atscvLayout}%
  \typeout{ATSCV TOKEN NameSize=\meaning\atscvNameSize}%
  \typeout{ATSCV TOKEN TitleSize=\meaning\atscvTitleSize}%
  \typeout{ATSCV TOKEN SectionSize=\meaning\atscvSectionSize}%
  \typeout{ATSCV TOKEN SectionBefore=\meaning\atscvSectionBefore}%
  \typeout{ATSCV TOKEN SectionAfter=\meaning\atscvSectionAfter}%
  \typeout{ATSCV TOKEN EntrySpace=\meaning\atscvEntrySpace}%
  \typeout{ATSCV TOKEN DividerThickness=\atscvDividerThickness}%
  \typeout{ATSCV DEBUG Preset=\atscvPreset Schema=\atscvSchema Color=\atscvColor Style=\atscvStyle Layout=\atscvLayout Language=\atscvLanguage}%
}

\AtBeginDocument{\color{cvtext}}
\endinput
