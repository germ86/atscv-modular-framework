\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{atscv-cv}[2026/05/03 ATS-safe CV macros]

\RequirePackage{atscv-base}

\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.35\baselineskip}

\newcommand{\cvname}[1]{\begingroup\atscvNameSize\bfseries\color{cvprimary}#1\par\endgroup}
\newcommand{\cvtitle}[1]{\begingroup\atscvTitleSize\color{cvmuted}#1\par\endgroup}
\newcommand{\cvcontact}[1]{\color{cvmuted}#1\par}

\newcommand{\cvsection}[1]{%
  \atscvSectionBefore
  {\atscvSectionSize\bfseries\color{cvprimary}#1\par}
  \vspace{0.2\baselineskip}
  \hrule height \atscvDividerThickness
  \atscvSectionAfter
}

\newcommand{\cventry}[3]{%
  \textbf{#1}\par
  \textit{#2}\par
  #3\par
  \atscvEntrySpace
}
\endinput
